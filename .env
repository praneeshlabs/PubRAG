# ─────────────────────────────────────────────────────────
# PubMed RAG System — Environment Variables
# Copy this file to .env and fill in your real values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────

# Anthropic API key (required)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-[Your API Key]
# NCBI email for Entrez API (required — NCBI policy)
# Use your real institutional or personal email.
# Registered emails get 10 req/sec instead of 3 req/sec.
NCBI_EMAIL=your.email@institution.edu
